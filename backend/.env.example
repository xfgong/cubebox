# Environment Configuration
ENV_FOR_DYNACONF=development

# LLM Provider API Keys (uncomment and set as needed)
CUBEBOX_LLM__PROVIDERS__CUBEBOX__BASE_URL=your-sensedeal-api-key
CUBEBOX_LLM__PROVIDERS__CUBEBOX__API_KEY=your-sensedeal-api-key

# CUBEBOX_LLM__PROVIDERS__OPENAI__API_KEY=your-openai-api-key
# CUBEBOX_LLM__PROVIDERS__ANTHROPIC__API_KEY=your-anthropic-api-key

# Database Configuration (when implemented)
# CUBEBOX_DATABASE__URL=postgresql://user:password@localhost:5432/cubebox

# Redis Configuration (when implemented)
# CUBEBOX_REDIS__URL=redis://localhost:6379/0

# Elasticsearch Configuration (when implemented)
# CUBEBOX_ELASTICSEARCH__URL=http://localhost:9200
